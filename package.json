{
	"name": "sokos-up-dare",
	"version": "1.0.0",
	"description": "Mikrofrontend for Utbetalingsportalen",
	"type": "module",
	"scripts": {
		"dev": "vite --mode mock",
		"dev:backend": "vite --mode backend",
		"dev:local": "vite --mode localbackend",
		"build": "tsc && vite build",
		"playwright": "playwright test",
		"biome:check": "biome check --files-ignore-unknown=true",
		"biome:fix": "biome check --write --no-errors-on-unmatched",
		"stylelint:check": "stylelint '**/*.css'",
		"stylelint:fix": "stylelint '**/*.css' --fix",
		"prepare": "husky"
	},
	"dependencies": {
		"@axe-core/playwright": "4.11.1",
		"@grafana/faro-web-sdk": "2.3.1",
		"@navikt/aksel-icons": "7.40.0",
		"@navikt/ds-css": "7.40.0",
		"@navikt/ds-react": "7.40.0",
		"axios": "1.15.0",
		"luxon": "3.7.2",
		"lz-string": "1.5.0",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-router": "7.14.0",
		"react-router-dom": "7.14.0",
		"swr": "2.4.1",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@navikt/aksel-stylelint": "7.40.0",
		"@playwright/test": "1.59.1",
		"@rollup/plugin-terser": "1.0.0",
		"@types/luxon": "3.7.1",
		"@types/node": "25.5.2",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.1",
		"autoprefixer": "10.4.27",
		"husky": "9.1.7",
		"lint-staged": "16.4.0",
		"msw": "2.13.2",
		"postcss": "8.5.9",
		"stylelint": "17.6.0",
		"stylelint-config-standard": "40.0.0",
		"typescript": "5.9.3",
		"vite": "8.0.8",
		"vite-plugin-css-injected-by-js": "4.0.1",
		"vite-plugin-environment": "1.1.3"
	},
	"msw": {
		"workerDirectory": [
			"public"
		]
	},
	"browserslist": {
		"production": [
			">0.2%",
			"not dead",
			"not op_mini all"
		],
		"development": [
			"last 1 chrome version",
			"last 1 firefox version"
		]
	},
	"stylelint": {
		"extends": [
			"stylelint-config-standard",
			"@navikt/aksel-stylelint/recommended"
		],
		"ignoreFiles": "dist/**/*"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": "biome check --write --no-errors-on-unmatched",
		"*.css": "stylelint --fix"
	},
	"engines": {
		"pnpm": ">=10.16.0",
		"node": ">=24.13.0"
	},
	"pnpm": {
		"overrides": {
			"flatted": ">=3.4.2",
			"picomatch": ">=4.0.4"
		}
	}
}
